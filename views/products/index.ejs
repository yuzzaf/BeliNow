<div class="container py-5">

  <!-- Hero Section -->
  <div class="text-center mb-5">
    <% if (user && user.role === "admin") { %>
      <h1 class="fw-bold">Manage Products</h1>
      <p class="text-muted">Create, update, and organize your catalog</p>
    <% } else { %>
      <h1 class="fw-bold">Discover Our Products</h1>
      <p class="text-muted">Find the best items with the best prices</p>
    <% } %>
    <% if (user && user.role === "admin") { %>
      <a href="/products/add" class="btn btn-dark mt-2">Add New Product</a>
    <% } %>
  </div>

  <form method="GET" action="/products" class="mb-4">
    <div class="row g-2">
      <div class="col-md-6">
        <input type="text" name="search" class="form-control" placeholder="Search" value="<%= search || '' %>">
      </div>
      <div class="col-md-4">
        <select name="categoryId" class="form-select">
          <option value="">All Categories</option>
          <% (categories || []).forEach(category => { %>
            <option value="<%= category.id %>" <%= +categoryId === category.id ? "selected" : "" %>>
              <%= category.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-dark">Filter</button>
      </div>
    </div>
  </form>

<% if (notifDeleteProduct) { %>
  <div class="alert alert-danger alert-dismissible fade show shadow-sm d-flex align-items-center justify-content-between mb-4"
       role="alert"
       style="border-radius: 10px;">

    <div class="d-flex align-items-center gap-2">
      <span style="font-size: 20px;">🗑️</span>
      <div>
        <strong>Product Deleted!</strong><br>
        <small class="text-muted">
          "<%= notifDeleteProduct %>"
        </small>
      </div>
    </div>
  </div>
<% } %>


  <% if (!data || data.length === 0) { %>

    <div class="alert alert-warning text-center">
      No Products Available
    </div>

  <% } else { %>

    <div class="row g-4">

      <% data.forEach(product => { %>

        <div class="col-md-4 col-lg-3">
          <div class="card h-100 shadow-sm border-0">

            <img src="<%= product.imageUrl %>" 
                 class="card-img-top"
                 style="height:220px; object-fit:cover;"
                 alt="<%= product.name %>">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title"><%= product.name %></h5>

              <p class="text-muted mb-2">
                <%= formatRupiah(product.price) %>
              </p>

              <% if (product.Categories && product.Categories.length) { %>
                <p class="small text-secondary">
                  Category:
                  <%= product.Categories.map(c => c.name).join(", ") %>
                </p>
              <% } %>

              <div class="mt-auto d-flex justify-content-between align-items-center gap-2">
                <a href="/products/<%= product.id %>" 
                   class="btn btn-sm btn-outline-primary">
                  Detail
                </a>

                <% if (user && user.role === "admin") { %>
                  <div class="d-flex gap-2">
                    <a href="/products/<%= product.id %>/edit" 
                      class="btn btn-sm btn-outline-success">
                      Edit
                    </a>

                    <form method="POST" action="/products/<%= product.id %>/delete" style="display:inline;">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </div>
                <% } %>

                <% if (user && user.role !== "admin") { %>
                  <form method="POST" action="/orders/create/<%= product.id %>" style="display:inline;" onsubmit="return handleAddToCartChoice(this);">
                    <input type="hidden" name="next" value="orders">
                    <button class="btn btn-sm btn-outline-primary" title="Add to Cart" aria-label="Add to Cart">
                      <i class="bi bi-cart-plus"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        </div>

      <% }) %>

    </div>

  <% } %>

</div>

<script>
  function handleAddToCartChoice(form) {
    var goToOrders = window.confirm(
      "Item akan ditambahkan ke cart.\nPilih OK untuk langsung ke Orders, atau Cancel untuk tetap di Products."
    );
    form.querySelector('input[name=\"next\"]').value = goToOrders ? "orders" : "products";
    return true;
  }
</script>
