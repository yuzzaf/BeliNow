<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Shopping Cart</h2>
    <div class="d-flex gap-2">
    <% if (order) { %>
      <a href="/orders/<%= order.id %>" class="btn btn-dark btn-sm">Buy</a>
    <% } %>
    <a href="/products" class="btn btn-outline-dark btn-sm">Back to Products</a>
  </div>
  </div>

  
  <% if (!order || !order.OrderDetails || order.OrderDetails.length === 0) { %>
    <div class="alert alert-warning text-center">Your cart is empty</div>
  <% } else { %>
    <div class="card shadow-sm border-0">
      <div class="card-body">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>Product</th>
              <th class="text-end">Price</th>
              <th class="text-center">Qty</th>
              <th class="text-end">Subtotal</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% let total = 0; %>
            <% order.OrderDetails.forEach(item => { %>
              <% const subtotal = item.price * item.quantity; total += subtotal; %>
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-3">
                    <img src="<%= item.Product?.imageUrl %>" alt="<%= item.Product?.name %>" style="width:60px;height:60px;object-fit:cover;border-radius:8px;">
                    <div><strong><%= item.Product?.name || "-" %></strong></div>
                  </div>
                </td>
                <td class="text-end"><%= formatRupiah(item.price) %></td>
                <td class="text-center">
                  <div class="d-inline-flex align-items-center gap-2">
                    <form method="POST" action="/orders/item/<%= item.id %>/decrease" style="display:inline;">
                      <button class="btn btn-sm btn-outline-secondary">-</button>
                    </form>
                    <span><%= item.quantity %></span>
                    <form method="POST" action="/orders/item/<%= item.id %>/increase" style="display:inline;">
                      <button class="btn btn-sm btn-outline-secondary">+</button>
                    </form>
                  </div>
                </td>
                <td class="text-end"><%= formatRupiah(subtotal) %></td>
                <td class="text-end">
                  <form method="POST" action="/orders/item/<%= item.id %>/delete" style="display:inline;">
                    <button class="btn btn-sm btn-outline-danger">Remove</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="d-flex justify-content-end mt-4">
          <h5 class="mb-0">Total: <strong><%= formatRupiah(total) %></strong></h5>

        </div>
      </div>
    </div>
  <% } %>
</div>
